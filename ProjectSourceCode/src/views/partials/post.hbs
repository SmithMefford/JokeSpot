<div class="row m-1">
    <div class="card bg-body-light mb-3">
        <div class="row align-items-center border-bottom">
            <div class="col-6 d-flex justify-content-start align-items-center">
                <div class="ratio rounded-circle overflow-hidden m-2" style="height: 48px;width: 48px;">
                    <img src="{{#if this.profile_photo_url}}{{this.profile_photo_url}}{{else}}/img/jokesPot.png{{/if}}" style="object-fit: cover;" alt="pfp placeholder">
                </div>
                <h2>{{this.author}}</h2>   
            </div>
            <div class="col-6 d-flex justify-content-end align-items-center">
                <p class="text-muted m-0">{{this.timestamp}}</p>
            </div>
        </div>
        <div class="card-body">
            <p style="font-size: x-large;">{{this.content}}</p>
            {{#if this.tags}}
                <span class="badge bg-secondary rounded-pill">{{this.tags}}</span>
            {{/if}}
        </div>
        <div class="card-footer">
            <div class="row align-items-center">
                <div class="col-6 d-flex justify-content-start align-items-center">
                    <form action="/rateJoke" method="POST" id="rateJoke_{{this.id}}">
                        <input type="hidden" name="joke_id" value="{{this.id}}">
                        <button type="submit" name="rate" value="upvote" onclick="alert('You liked this post!')" style="font-size: x-large; border: none; background: none;">😂</button>
                        <button type="submit" name="rate" value="downvote" onclick="alert('You disliked this post!')" style="font-size: x-large; border: none; background: none;">😢</button>
                    </form>
                </div>
                <div class="col-6 d-flex justify-content-end align-items-center">
                    <button type="button" class="btn btn-purple henny-penny-regular" data-bs-toggle="modal" data-bs-target="#reportForm_{{this.id}}">Report</button>
                </div>
            </div>
        </div>
    </div>
</div>

{{!-- Report form for joke --}}
<div class="modal" id="reportForm_{{this.id}}">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4>Report a joke.</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/reportJoke" method="post">                    
                <div class="modal-body">
                    <div class="container flex-column">  
                        <div class="pg-2">
                            <h3>Report on joke #{{this.id}}.</h3>
                        </div>
                        <div class="pb-2">
                            <label for="report_reason">Reason for report?</label>
                        </div>
                        <div class="pb-2">
                            <select name="report_reason" id="reason" class="form-select">
                                <option value="spam">Spam</option>
                                <option value="offensive">Offensive</option>
                                <option value="misinformation">Misinformation</option>
                                <option value="other">Other</option>
                            </select>                             
                        </div>
                        <div class="pb-2 mt-2">
                            <label for="report_explanation">Further explain the reason.</label>
                        </div>
                        <div class="pb-2">
                            <textarea name="report_explanation" id="explanation" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary henny-penny-regular" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-purple henny-penny-regular">Submit</button>
                </div>
                <input type="hidden" name="joke_id" value="{{this.id}}">
            </form>
        </div>
    </div>
</div>
        <div class="row m-1">
            <div class="card bg-body-light">
                <div class="row align-items-center border-bottom">
                    <div class="col-6 d-flex justify-content-start align-items-center">
                        <div class="ratio rounded-circle overflow-hidden m-2" style="height: 48px;width: 48px;">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/b/bc/Juvenile_Ragdoll.jpg" style="object-fit: cover;" alt="pfp placeholder">
                        </div>
                        <h2>TestUser</h2>
                    </div>
                    <div class="col-6 d-flex justify-content-end align-items-center">
                        <p>Timestamp</p>
                    </div>
                </div>
                <div class="card-body">
                    <p style="font-size: x-large;">This is where a joke would go.</p>
                </div>
                <div class="card-footer">
                    <div class="row align-items-center">
                        <div class="col-6 d-flex justify-content-start align-items-center">
                            <form action="/rateJoke" method="POST" id="rateJoke">
                                {{!-- <button type="submit" name="rate" value="upvote" onclick="alert('You liked this post!')" style="font-size: x-large;">😂</button>
                                <button type="submit" name="rate" value="downvote" onclick="alert('You disliked this post!')" style="font-size: x-large;">😢</button> --}}
                                {{!-- <input type="radio" id="like" name="rating" value="upvote" onchange="this.form.querySelector('#secret_submit').click()"> --}}
                                <input type="checkbox" id="like" name="rate" value="upvote" onclick="switchInteraction(this)">
                                <label for="like" style="font-size: x-large;">
                                    <i class="fa-solid fa-heart"></i>
                                </label>
                                {{!-- <input type="radio" id="dislike" name="rating" value="downvote" onchange="this.form.querySelector('#secret_submit').click()"> --}}
                                <input type="checkbox" id="dislike" name="rate" value="downvote" onclick="switchInteraction(this)">
                                <label for="dislike" style="font-size: x-large;">
                                    <i class="fa-solid fa-heart-crack"></i>
                                </label>
                                <button id="secret_submit" type="submit" style="display: none"></button>
                            </form>
                        </div>
                        <div class="col-6 d-flex justify-content-end align-items-center">
                            <button type="button" class="btn btn-purple henny-penny-regular" data-bs-toggle="modal" data-bs-target="#reportForm">Report</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {{!-- Report form for joke --}}
        <div class="modal" id="reportForm">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4>Report a joke.</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form action="/reportJoke" method="post" id="reportJoke">                    
                        <input type="hidden" name="joke_id" value="n">
                        <div class="modal-body">
                            <div class="container flex-column">  
                                <div class="pg-2">
                                    <h3>Report on joke #n.</h3>
                                </div>
                                <div class="pb-2">
                                    <label for="report_reason">Reason for report?</label>
                                </div>
                                <div class="pb-2">
                                    <select name="report_reason" id="reason">
                                        <option value="spam">Spam</option>
                                        <option value="offensive">Offensive</option>
                                        <option value="misinformation">Misinformation</option>
                                        <option value="other">Other</option>
                                    </select>                             
                                </div>
                                <div class="pb-2">
                                    <label for="report_explanation">Further explain the reason.</label>
                                </div>
                                <div class="pb-2">
                                    <textarea name="report_explanation" id="explanation"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-purple henny-penny-regular" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-purple henny-penny-regular">Submit</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
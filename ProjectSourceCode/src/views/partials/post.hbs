    <div class="row mx-1 my-3">
        <div class="card bg-body-light">
            <div class="row align-items-center border-bottom">
                <div class="col-6 d-flex justify-content-start align-items-center">
                    <div class="ratio rounded-circle overflow-hidden m-2" style="height: 48px;width: 48px;">
                        <img src={{ profilePicture }} style="object-fit: cover;" alt="pfp placeholder">
                    </div>
                    <h2>{{ username }}</h2>
                </div>
                <div class="col-6 d-flex justify-content-end align-items-center">
                    <p>{{ timestamp }}</p>
                </div>
            </div>
            <div class="card-body">
                <p style="font-size: x-large;">{{ content }}</p>
            </div>
            <div class="card-footer">
                <div class="row align-items-center">
                    <div class="col-6 d-flex justify-content-start align-items-center">
                        <form action="/rateJoke" method="POST" id="rateJoke{{ jokeID }}" name="rateJoke">
                            <input type="hidden" name="joke_id" value="{{ jokeID }}">
                            <input type="checkbox" id="like{{ jokeID }}" name="rate{{ jokeID }}" value="like" onclick="switchInteraction(this)">
                            <label for="like{{ jokeID }}" style="font-size: x-large;">
                                <i class="fa-solid fa-heart"></i>
                            </label>
                            <input type="checkbox" id="dislike{{ jokeID }}" name="rate{{ jokeID }}" value="dislike" onclick="switchInteraction(this)">
                            <label for="dislike{{ jokeID }}" style="font-size: x-large;">
                                <i class="fa-solid fa-heart-crack"></i>
                            </label>
                            {{!-- <button id="secret_submit" type="submit" style="display: none"></button> --}}
                        </form>
                    </div>
                    <div class="col-6 d-flex justify-content-end align-items-center">
                        <button type="button" class="btn btn-purple henny-penny-regular" data-bs-toggle="modal" data-bs-target="#reportForm{{ jokeID }}">Report</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{!-- Report form for joke --}}
    <div class="modal" id="reportForm{{ jokeID }}">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h4>Report a joke.</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/reportJoke" method="post" id="reportJoke{{ jokeID }}" name="reportJoke">                    
                    <input type="hidden" name="joke_id" value="{{ jokeID }}">
                    <div class="modal-body">
                        <div class="container flex-column">  
                            <div class="pg-2">
                                <h3>Report joke #{{ jokeID }}.</h3>
                            </div>
                            <div class="pb-2">
                                <label for="report_reason">Reason for report?</label>
                            </div>
                            <div class="pb-2">
                                <select name="report_reason" id="reason">
                                    <option value="spam">Spam</option>
                                    <option value="offensive">Offensive</option>
                                    <option value="misinformation">Misinformation</option>
                                    <option value="other">Other</option>
                                </select>                             
                            </div>
                            <div class="pb-2">
                                <label for="report_explanation">Further explain the reason.</label>
                            </div>
                            <div class="pb-2">
                                <textarea name="report_explanation" id="explanation"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-purple henny-penny-regular" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-purple henny-penny-regular">Submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
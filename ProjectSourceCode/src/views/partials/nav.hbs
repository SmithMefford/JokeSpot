{{#if user}}
    <div class="dropdown">
      <img
        id="profile-icon"
        src="/img/happyFace.png"
        alt="Profile"
        width="40"
        height="40"
        class="rounded-circle border border-2 border-dark"
        data-bs-toggle="dropdown"
        role="button"
        aria-expanded="false"
        style="cursor:pointer; object-fit:cover;"
      >
      <ul class="dropdown-menu dropdown-menu-end">
        <li><span class="dropdown-item-text text-muted">{{user.username}}</span></li> <!-- Change to use user profile pictures when added-->
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item" href="/#">Profile</a></li> <!-- change /# to API route once profile page added -->

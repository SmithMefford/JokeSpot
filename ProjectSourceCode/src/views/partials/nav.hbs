        <li><a class="dropdown-item" href="/settings">Settings</a></li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item" href="/logout">Logout</a></li>
      </ul>
    </div>
{{else}}
    <div class="nav-item me-3">
        <a class="nav-link" href="/login">Login</a>
    </div>
{{/if}}
       

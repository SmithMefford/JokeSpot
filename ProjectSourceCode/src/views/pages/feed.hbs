<div class="container justify-content-center align-items-center" id="feed_page">
    <h1 class="henny-penny-regular my-4">Feed the doomscroll...</h1>
    <div class="pb-2">
        <form action="/search" method="POST" id="searchJokes" name="searchJokes" onsubmit="timeoutButton(document.getElementById('submitSearch'))">
            <label for="searchType">Search by...</label>
            <select name="searchType" id="searchType">
                <option value="content">Content</option>
                <option value="tags">Tags</option>
            </select>
            <input type="text" name="searchBar" class="mx-2">
            
            <label for="sortOrder">Sort:</label>
            <select name="sortOrder" id="sortOrder" onchange="this.form.requestSubmit()">
                <option value="newest">Newest First</option>
                <option value="oldest">Oldest First</option>
            </select>
            
            <button id="submitSearch" type="submit" class="btn btn-purple henny-penny-regular ms-2" name="searchButton">Search!</button>
        </form>
    </div>
    <div class="container border-top border-bottom rounded justify-content-center align-items-center overflow-auto" id="feedBox" style="height: 500px;">

    </div>
    <form class="text-center my-3" action="/loadJokes" method="GET" id="loadJokes" name="loadJokes">
        <button class="btn btn-purple henny-penny-regular" type="submit" style="font-size: x-large;">Entertain me, Jester!</button>
    </form>
    <div class="text-center my-3">
        <a href="/home" class="btn btn-purple henny-penny-regular">
            Home
        </a>
    </div>
</div>
<script>
let jokesLoaded = 0;

async function loadJoke() {
  const res = await fetch('/loadJokes', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ loaded: jokesLoaded })
  });

  const html = await res.text();

  document.getElementById('feedBox').innerHTML += html;
  jokesLoaded++;
}

document.getElementById('jokeBtn').addEventListener('click', (e) => {
  e.preventDefault();
  loadJoke();
});
</script>
<script>
const autoRefreshEnabled = {{#if user.auto_refresh}}true{{else}}false{{/if}};

if (autoRefreshEnabled) {
  setInterval(loadJoke, 2000);
}
</script>
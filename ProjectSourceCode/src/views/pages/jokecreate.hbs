<h2 class="text-center henny-penny-regular" style="margin-top: 15px;">Create a Joke</h2>

{{#if user}}
<p class="text-center henny-penny-regular" style="margin-top: 15px;">{{user.username}}, share your joke!</p>
{{/if}}

<form id="postJoke" name="postJoke" action="/jokecreate" method="POST" style="text-align: center; margin-top: 20px;">
    <div style="margin-bottom: 15px; display: flex; flex-direction: column; align-items: center;">
        <textarea id="jokeContent" name="jokeContent" rows="10" cols="60" 
                  placeholder="Why did the chicken cross the road..." 
                  class="form-control mx-auto"
                  style="max-width: 500px; text-align: center;"></textarea>
        <div id="hateSpeechFeedback" class="invalid-feedback" style="width: 500px;">
            Hate speech detected. Posting blocked.
        </div>
    </div>
    
    <div style="margin-bottom: 15px; display: flex; justify-content: center;">
        <textarea id="tags" name="tags" rows="2" cols="60" placeholder="Type your tags here... (e.g. tag_1,tag_2,tag_3)" style="text-align: center;"></textarea>
    </div>
    
    <div style="margin-top: 15px;">
        <button type="button" id="postBtn" class="henny-penny-regular btn-purple my-2" 
                style="font-size: 1rem; padding: 0.75rem 1.5rem;" disabled>
            Loading Filters...
        </button>
    </div>
</form>

<div id="messageBox" class="alert mx-auto text-center rounded d-none" style="width: 60ch;">
  {{> message}}
</div>

<form action="/home" method="GET" style="text-align: center; margin-top: 20px; margin-bottom: 20px;">
    <button type="submit" class="henny-penny-regular btn-purple" style="font-size: 1rem; padding: 0.75rem 1.5rem;">Back to Home</button>
</form>

{{!-- Profanity confirmation modal (Restored) --}}
<div class="modal fade" id="profanityConfirmModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4>⚠️ Profanity Detected</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Your joke contains profanity. It will be automatically censored before being posted.</p>
                <p>Do you want to post it anyway?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary henny-penny-regular" data-bs-dismiss="modal">Go Back & Edit</button>
                <button type="button" class="btn btn-purple henny-penny-regular" id="confirmPostBtn">Post Anyway</button>
            </div>
        </div>
    </div>
</div>

<script>
let PROFANITY_REGEX = null;
let HATE_SPEECH_REGEX = null;
let confirmModal = null;

const jokeForm = document.getElementById('postJoke');
const textarea = document.getElementById('jokeContent');
const postBtn  = document.getElementById('postBtn');
const confirmBtn = document.getElementById('confirmPostBtn');
const feedback = document.getElementById('hateSpeechFeedback');

// Helper to build regex from CSV array
function buildRegex(list) {
    if (!list || list.length === 0) return new RegExp('^$'); // empty regex fallback
    const sorted = [...list].sort((a, b) => b.length - a.length);
    const parts  = sorted.map(word => {
        const escaped = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        const prefix  = /\w/.test(word[0]) ? '(?<!\\w)' : '';
        const suffix  = /\w/.test(word[word.length - 1]) ? '(?!\\w)' : '';
        return `${prefix}${escaped}${suffix}`;
    });
    return new RegExp(parts.join('|'), 'gi');
}

// Fetch BOTH lists simultaneously
Promise.all([
    fetch('/profanityList').then(res => res.json()).catch(() => []),
    fetch('/hateSpeechList').then(res => res.json()).catch(() => [])
]).then(([profanityList, hateSpeechList]) => {
    PROFANITY_REGEX = buildRegex(profanityList);
    HATE_SPEECH_REGEX = buildRegex(hateSpeechList);
    
    postBtn.disabled = false;
    postBtn.textContent = 'Post Joke';
});

function submitForm() {
    jokeForm.submit();
}

postBtn.addEventListener('click', () => {
    // Reset validations
    textarea.classList.remove('is-invalid');
    feedback.style.display = 'none';
    
    if (HATE_SPEECH_REGEX) HATE_SPEECH_REGEX.lastIndex = 0;
    if (PROFANITY_REGEX) PROFANITY_REGEX.lastIndex = 0;

    // Layer 1: Hate Speech (Hard Block)
    if (HATE_SPEECH_REGEX && HATE_SPEECH_REGEX.test(textarea.value) && textarea.value !== "") {
        textarea.classList.add('is-invalid');
        feedback.style.display = 'block';
    } 
    // Layer 2: Profanity (Soft Catch / Warning)
    else if (PROFANITY_REGEX && PROFANITY_REGEX.test(textarea.value) && textarea.value !== "") {
        if (!confirmModal) {
            confirmModal = new bootstrap.Modal(document.getElementById('profanityConfirmModal'));
        }
        confirmModal.show();
    } 
    // Layer 3: Clean (Submit)
    else {
        submitForm();
    }
});

confirmBtn.addEventListener('click', () => {
    confirmModal.hide();
    document.getElementById('profanityConfirmModal').addEventListener('hidden.bs.modal', submitForm, { once: true });
});
</script>
<h2 class="text-center henny-penny-regular" style="margin-top: 15px;">Create a Joke</h2>

{{#if user}}
<p class="text-center henny-penny-regular" style="margin-top: 15px;">{{user.username}}, share your joke!</p>
{{/if}}

<form action="/create-joke" method="POST" style="text-align: center; margin-top: 20px;">
    <div style="margin-bottom: 15px; display: flex; justify-content: center;">
        <textarea id="jokeContent" name="jokeContent" rows="10" cols="60" placeholder="Type your joke here..." style="text-align: center;, cursive;"></textarea>
    </div>
    <div style="margin-bottom: 15px; display: flex; justify-content: center;">
        <textarea id="jokeContent" name="jokeContent" rows="2" cols="60" placeholder="Type your tags here..." style="text-align: center;, cursive;"></textarea>
    </div>
    <div style="margin-top: 15px;">
        <button type="submit" class="henny-penny-regular btn-purple" style="font-size: 1rem; padding: 0.75rem 1.5rem;">Post Joke</button>
    </div>
</form>

<form action="/home" method="GET" style="text-align: center; margin-top: 20px;">
    <button type="submit" class="henny-penny-regular btn-purple" style="font-size: 1rem; padding: 0.75rem 1.5rem;">Back to Home</button>
</form>
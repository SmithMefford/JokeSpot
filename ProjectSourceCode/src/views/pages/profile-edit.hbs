<div class="container my-5">
    <div class="card mx-auto shadow" style="max-width: 600px;">
        <div class="card-header text-center mt-3" style="background-color: transparent; border-bottom: none;">
            <h3 class="henny-penny-regular text-primary">Edit Profile</h3>
        </div>
        <div class="card-body">
            
            <form action="/profile/edit" method="POST" enctype="multipart/form-data">
                
                <div class="mb-4 text-center">
                    <p class="mb-2 fw-bold">Current Photo:</p>
                    <img src="{{user.profile_photo_url}}" alt="Profile Photo" class="rounded-circle mb-3 border" style="width: 120px; height: 120px; object-fit: cover;">
                    <br>
                    
                    <label for="profile_picture" class="form-label fw-bold text-start w-100 mt-2">Upload New Profile Photo</label>
                    <input type="file" class="form-control" id="profile_picture" name="profile_picture" accept="image/png, image/jpeg, image/jpg">
                    <div class="form-text text-start">Accepted formats: .jpg, .png</div>
                </div>

                <div class="mb-4 form-check mt-4">
                    <input type="checkbox" class="form-check-input border-secondary" id="isPrivate" name="is_private" {{#if user.is_private}}checked{{/if}}>
                    <label class="form-check-label fw-bold" for="isPrivate">Make Account Private</label>
                    <div class="form-text">Private accounts hide stats and rankings from other users.</div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-purple py-2 fw-bold">Save Changes</button>
                    <a href="/profile" class="btn btn-outline-secondary py-2 fw-bold">Cancel</a>
                </div>

            </form>
        </div>
    </div>
</div>
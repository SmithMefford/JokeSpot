<div class="container mt-5">
    <h2 class="text-center henny-penny-regular mb-4">Edit Profile</h2>
    <div class="row justify-content-center">
        <div class="col-md-6 border p-4 rounded shadow-sm bg-body-light">
            
            <form action="/profile/edit" method="POST" enctype="multipart/form-data">
                
                <div class="mb-4 text-center">
                    <p class="mb-2">Current Photo:</p>
                    <img src="{{user.profile_photo_url}}" alt="Profile Photo" class="rounded-circle mb-3 border" style="width: 120px; height: 120px; object-fit: cover;">
                    <br>
                    <label for="profile_picture" class="form-label fw-bold">Upload New Profile Photo</label>
                    <input type="file" class="form-control" id="profile_picture" name="profile_picture" accept="image/png, image/jpeg, image/jpg">
                    <div class="form-text">Accepted formats: .jpg, .png</div>
                </div>

                <div class="mb-4 form-check d-flex justify-content-center align-items-center gap-2">
                    <input type="checkbox" class="form-check-input mt-0" id="is_private" name="is_private" {{#if user.is_private}}checked{{/if}}>
                    <label class="form-check-label" for="is_private">Make Profile Private</label>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-purple henny-penny-regular" style="font-size: 1.2rem;">Save Changes</button>
                    <a href="/profile" class="btn btn-secondary henny-penny-regular">Cancel</a>
                </div>
            </form>
            
        </div>
    </div>
</div>
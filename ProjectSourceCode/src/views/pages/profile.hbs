<div class="container my-5">
    <div class="card mx-auto shadow" style="max-width: 600px;">
        <div class="card-body text-center">
            
            {{#if is_owner}}
                <div class="mb-2">
                    <a href="/profile-edit" title="Click to update profile picture" style="display: inline-block; position: relative; text-decoration: none;">
                        
                        <img src="{{profile_photo_url}}" alt="Profile Photo" class="rounded-circle border border-3" style="width: 150px; height: 150px; object-fit: cover; transition: opacity 0.2s;" id="profile-icon" onmouseover="this.style.opacity=0.7" onmouseout="this.style.opacity=1">
                        
                        <div style="position: absolute; bottom: 10px; right: 10px; background: white; border-radius: 50%; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 5px rgba(0,0,0,0.3); pointer-events: none;">
                            <i class="fa-solid fa-camera text-primary"></i>
                        </div>
                    </a>
                </div>
                <p class="text-muted small mb-3">Click photo to update</p>
            {{else}}
                <img src="{{profile_photo_url}}" alt="Profile Photo" class="rounded-circle mb-3 border border-3" style="width: 150px; height: 150px; object-fit: cover;" id="profile-icon">
            {{/if}}
            
            <h2 class="henny-penny-regular mb-0">{{display_name}}</h2>
            <p class="text-muted">@{{username}}</p>

            {{#if is_private_view}}
                <div class="alert alert-secondary mt-4" role="alert">
                    <i class="fa-solid fa-lock"></i> This account is private. Profile stats are hidden.
                </div>
            {{else}}
                <div class="mt-4">
                    <h4 class="henny-penny-regular text-primary">{{rating_title}}</h4>
                    
                    <div class="row mt-3">
                        <div class="col-6 border-end">
                            <h5>Total Likes</h5>
                            <p class="fs-4">{{total_likes}} <i class="fa-solid fa-heart text-danger"></i></p>
                        </div>
                        <div class="col-6">
                            <h5>Leaderboard Rank</h5>
                            <p class="fs-4">#{{rank}}</p>
                        </div>
                    </div>
                </div>
            {{/if}}

            </div>
    </div>
</div>
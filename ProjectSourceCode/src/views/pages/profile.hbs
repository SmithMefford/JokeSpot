<div class="container my-5">
    <div class="card mx-auto shadow" style="max-width: 600px;">
        <div class="card-body text-center">
            
            <img src="{{profile_photo_url}}" alt="Profile Photo" class="rounded-circle mb-3 border border-3" style="width: 150px; height: 150px; object-fit: cover;" id="profile-icon">
            
            <h2 class="henny-penny-regular mb-0">{{display_name}}</h2>
            <p class="text-muted">@{{username}}</p>

            {{#if is_private_view}}
                <div class="alert alert-secondary mt-4" role="alert">
                    <i class="fa-solid fa-lock"></i> This account is private. Profile stats are hidden.
                </div>
            {{else}}
                <div class="mt-4">
                    <h4 class="henny-penny-regular text-primary">{{rating_title}}</h4>
                    
                    <div class="row mt-3">
                        <div class="col-6 border-end">
                            <h5>Average Rating</h5>
                            <p class="fs-4">{{average_rating}} <i class="fa-solid fa-star text-warning"></i></p>
                        </div>
                        <div class="col-6">
                            <h5>Leaderboard Rank</h5>
                            <p class="fs-4">#{{rank}}</p>
                        </div>
                    </div>
                </div>
            {{/if}}

            {{#if is_owner}}
                <div class="mt-4">
                    <a href="/profile/edit" class="btn btn-purple px-4 py-2 rounded-pill">Edit Profile</a>
                </div>
                <div class="mt-4">
                    <a href="/settings" class="btn btn-purple px-4 py-2 rounded-pill">Edit Settings</a>
                </div>
            {{/if}}
        </div>
    </div>
</div>